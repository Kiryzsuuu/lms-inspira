# Backend (Express)
# Copy this file to server/.env

# Azure App Service provides PORT automatically; keep the default unless running locally.
PORT=4000

# MongoDB connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# JWT secret (min 16 chars)
JWT_SECRET=change_me_to_a_long_random_secret

# Allowed frontend origins for CORS.
# - Use a single origin, or multiple origins separated by commas.
# - Example Azure: https://<your-frontend-app>.azurewebsites.net
CLIENT_ORIGIN=http://localhost:5173

# Midtrans (optional)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_FEE_PERCENT=0
MIDTRANS_FEE_RULES_JSON=

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
